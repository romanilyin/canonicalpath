{
  "name": "canonicalpath-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "spec:validate": "node scripts/validate-spec.mjs",
    "check:changelog": "node scripts/check-changelog.mjs",
    "check:error-taxonomy": "node scripts/check-error-taxonomy.mjs",
    "check:licenses": "node scripts/check-package-license-layout.mjs",
    "check:unity-mcp-contract": "pnpm spec:validate && pnpm check:error-taxonomy && pnpm unity:mcp:path-scopes:vectors && node scripts/check-unity-mcp-contract.mjs",
    "verify": "pnpm spec:validate && pnpm check:error-taxonomy && pnpm check:licenses && node scripts/check-unity-mcp-contract.mjs && pnpm -C packages/ts typecheck && pnpm -C packages/ts test && pnpm ts:build && pnpm ts:package:smoke && pnpm ts:pack:dry-run && pnpm js:standalone:typecheck && pnpm js:standalone:build && pnpm js:standalone:build:smoke && pnpm js:standalone:test && pnpm unity:pack:dry-run && go test ./packages/go/... && pnpm scoped-daemon:smoke && pnpm vectors && pnpm python:vectors && pnpm dart:vectors && pnpm csharp:vectors && pnpm swift:vectors && pnpm kotlin:vectors && pnpm c:vectors && pnpm rust:vectors && pnpm cpp:vectors && pnpm haxe:vectors && pnpm gdscript:vectors && pnpm bash:smoke && pnpm cmd:smoke && pnpm unity:canonicalpath:vectors && pnpm unity:bridge:vectors && pnpm unity:mcp:path-scopes:vectors && pnpm unity:canonicalfs:transport:smoke && pnpm unity:burst:surface && pnpm unity:burst:probe && pnpm unity:editmode:matrix && pnpm ps:test",
    "test": "pnpm verify",
    "typecheck": "pnpm -C packages/ts typecheck",
    "lint": "pnpm -C packages/ts lint",
    "format": "pnpm -C packages/ts format",
    "go:test": "go test ./packages/go/...",
    "go:race": "go test -race ./packages/go/...",
    "go:alloc": "go test ./packages/go/canonicalpath -run TestCanonicalPathAllocationBudget -count=1",
    "ts:test": "pnpm -C packages/ts test",
    "ts:build": "pnpm -C packages/ts build",
    "ts:package:smoke": "pnpm -C packages/ts package:smoke",
    "ts:pack:dry-run": "pnpm -C packages/ts pack:dry-run",
    "ts:alloc": "pnpm -C packages/ts test test/allocation.test.ts",
    "js:standalone:typecheck": "pnpm -C packages/javascript-standalone typecheck",
    "js:standalone:build": "pnpm -C packages/javascript-standalone build",
    "js:standalone:build:smoke": "pnpm -C packages/javascript-standalone build:smoke",
    "js:standalone:pack:dry-run": "pnpm -C packages/javascript-standalone pack:dry-run",
    "js:standalone:test": "pnpm -C packages/javascript-standalone test",
    "js:standalone:alloc": "pnpm -C packages/javascript-standalone alloc",
    "python:vectors": "node scripts/run-python-canonicalpath-vectors.mjs",
    "python:alloc": "node scripts/run-python-allocation-check.mjs",
    "dart:vectors": "node scripts/run-dart-canonicalpath-vectors.mjs",
    "dart:alloc": "node scripts/run-dart-allocation-check.mjs",
    "csharp:vectors": "node scripts/run-csharp-canonicalpath-vectors.mjs",
    "csharp:alloc": "node scripts/run-csharp-allocation-check.mjs",
    "swift:vectors": "node scripts/run-swift-canonicalpath-vectors.mjs",
    "swift:alloc": "node scripts/run-swift-allocation-check.mjs",
    "kotlin:vectors": "node scripts/run-kotlin-canonicalpath-vectors.mjs",
    "kotlin:alloc": "node scripts/run-kotlin-allocation-check.mjs",
    "c:vectors": "node scripts/run-c-canonicalpath-vectors.mjs",
    "c:alloc": "node scripts/run-c-allocation-check.mjs",
    "rust:vectors": "node scripts/run-rust-canonicalpath-vectors.mjs",
    "rust:alloc": "node scripts/run-rust-allocation-check.mjs",
    "cpp:vectors": "node scripts/run-cpp-canonicalpath-vectors.mjs",
    "cpp:alloc": "node scripts/run-cpp-allocation-check.mjs",
    "haxe:vectors": "node scripts/run-haxe-canonicalpath-vectors.mjs",
    "haxe:alloc": "node scripts/run-haxe-allocation-check.mjs",
    "gdscript:vectors": "node scripts/run-gdscript-canonicalpath-vectors.mjs",
    "gdscript:alloc": "node scripts/run-gdscript-allocation-check.mjs",
    "bash:smoke": "node scripts/run-bash-wrapper-check.mjs",
    "bash:alloc": "node scripts/run-bash-wrapper-check.mjs --allocation",
    "cmd:smoke": "node scripts/run-windows-cmd-wrapper-check.mjs",
    "cmd:alloc": "node scripts/run-windows-cmd-wrapper-check.mjs --allocation",
    "scoped-daemon:smoke": "node scripts/run-scoped-daemon-smoke.mjs",
    "ps:alloc": "node scripts/run-powershell-allocation-check.mjs",
    "ps:transport:alloc": "node scripts/run-powershell-transport-allocation-check.mjs",
    "unity:pack:dry-run": "pnpm -C packages/unity pack:dry-run",
    "unity:pack:signed": "node scripts/pack-unity-signed.mjs",
    "unity:npm:ping": "node scripts/run-npm-with-env-token.mjs ping",
    "unity:npm:whoami": "node scripts/run-npm-with-env-token.mjs whoami",
    "unity:npm:publish:dry-run": "node scripts/run-npm-with-env-token.mjs --cwd packages/unity publish --dry-run",
    "unity:npm:publish:unsigned": "node scripts/run-npm-with-env-token.mjs --cwd packages/unity publish",
    "unity:npm:publish:unsigned:dry-run": "node scripts/run-npm-with-env-token.mjs --cwd packages/unity publish --dry-run",
    "unity:npm:publish:signed": "node scripts/publish-unity-signed.mjs",
    "unity:npm:publish:signed:dry-run": "node scripts/publish-unity-signed.mjs --dry-run",
    "unity:npm:publish": "node scripts/run-npm-with-env-token.mjs --cwd packages/unity publish",
    "unity:canonicalpath:alloc": "node scripts/run-unity-canonicalpath-allocation-check.mjs",
    "unity:canonicalpath:vectors": "node scripts/run-unity-canonicalpath-vectors.mjs",
    "unity:bridge:vectors": "node scripts/run-unity-bridge-vectors.mjs",
    "unity:canonicalfs:transport:smoke": "node scripts/run-unity-canonicalfs-transport-smoke.mjs",
    "unity:mcp:path-scopes:vectors": "node scripts/run-unity-mcp-path-scope-vectors.mjs",
    "unity:burst:surface": "node scripts/run-unity-burst-surface-smoke.mjs",
    "unity:burst:probe": "node scripts/run-unity-burst-compiler-probe.mjs",
    "unity:burst:alloc": "node scripts/run-unity-burst-allocation-probe.mjs",
    "unity:burst:alloc:2022.3": "UNITY_BURST_ALLOC_PROBE=1 UNITY_BURST_REQUIRED_VERSION_PREFIX=2022.3 node scripts/run-unity-burst-allocation-probe.mjs",
    "unity:burst:alloc:6000.1": "UNITY_BURST_ALLOC_PROBE=1 UNITY_BURST_REQUIRED_VERSION_PREFIX=6000.1 node scripts/run-unity-burst-allocation-probe.mjs",
    "unity:burst:alloc:6000.2": "UNITY_BURST_ALLOC_PROBE=1 UNITY_BURST_REQUIRED_VERSION_PREFIX=6000.2 node scripts/run-unity-burst-allocation-probe.mjs",
    "unity:burst:alloc:6000.3": "UNITY_BURST_ALLOC_PROBE=1 UNITY_BURST_REQUIRED_VERSION_PREFIX=6000.3 node scripts/run-unity-burst-allocation-probe.mjs",
    "unity:burst:alloc:6000.4": "node scripts/run-unity-burst-allocation-6000-4.mjs",
    "unity:burst:alloc:matrix": "node scripts/run-unity-version-matrix.mjs burst-alloc",
    "unity:editmode": "node scripts/run-unity-editmode-tests.mjs",
    "unity:editmode:2022.3": "UNITY_REQUIRED_VERSION_PREFIX=2022.3 node scripts/run-unity-editmode-tests.mjs",
    "unity:editmode:6000.1": "UNITY_REQUIRED_VERSION_PREFIX=6000.1 node scripts/run-unity-editmode-tests.mjs",
    "unity:editmode:6000.2": "UNITY_REQUIRED_VERSION_PREFIX=6000.2 node scripts/run-unity-editmode-tests.mjs",
    "unity:editmode:6000.3": "UNITY_REQUIRED_VERSION_PREFIX=6000.3 node scripts/run-unity-editmode-tests.mjs",
    "unity:editmode:6000.4": "UNITY_REQUIRED_VERSION_PREFIX=6000.4 node scripts/run-unity-editmode-tests.mjs",
    "unity:editmode:matrix": "node scripts/run-unity-version-matrix.mjs editmode",
    "alloc": "pnpm go:alloc && pnpm ts:alloc && pnpm js:standalone:alloc && pnpm python:alloc && pnpm dart:alloc && pnpm csharp:alloc && pnpm swift:alloc && pnpm kotlin:alloc && pnpm c:alloc && pnpm rust:alloc && pnpm cpp:alloc && pnpm haxe:alloc && pnpm gdscript:alloc && pnpm bash:alloc && pnpm cmd:alloc && pnpm ps:alloc && pnpm ps:transport:alloc && pnpm unity:canonicalpath:alloc && pnpm unity:burst:alloc && pnpm unity:burst:alloc:matrix",
    "vectors": "pnpm vectors:go && pnpm vectors:ts && pnpm vectors:js-standalone && pnpm vectors:compare",
    "vectors:go": "go run ./packages/go/cmd/vector-results -out tmp/vector-results/go.json",
    "vectors:ts": "VECTOR_RESULTS_OUT=../../tmp/vector-results/ts.json pnpm -C packages/ts exec vitest run test/vector-results.test.ts",
    "vectors:js-standalone": "VECTOR_RESULTS_OUT=../../tmp/vector-results/js-standalone.json pnpm -C packages/javascript-standalone exec vitest run test/vectors.test.ts",
    "vectors:compare": "node scripts/compare-results.mjs tmp/vector-results/go.json tmp/vector-results/ts.json && node scripts/compare-results.mjs tmp/vector-results/go.json tmp/vector-results/js-standalone.json",
    "ps:test": "node scripts/run-powershell-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fast-check": "^4.9.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
