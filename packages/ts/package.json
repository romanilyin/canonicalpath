{
  "name": "@romanilyin/canonicalpath",
  "version": "2026.5.18-2",
  "description": "Shared CanonicalPath identity and daemon client helpers for cross-runtime tools.",
  "license": "LicenseRef-Stinger-Royalty-Free-EULA-1.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romanilyin/canonicalpath.git",
    "directory": "packages/ts"
  },
  "homepage": "https://github.com/romanilyin/canonicalpath#readme",
  "bugs": {
    "url": "https://github.com/romanilyin/canonicalpath/issues"
  },
  "keywords": ["canonicalpath", "canonicalfs", "path", "filesystem", "path-traversal"],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/canonicalpath/index.js",
  "types": "./dist/canonicalpath/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/canonicalpath/index.d.ts",
      "import": "./dist/canonicalpath/index.js",
      "default": "./dist/canonicalpath/index.js"
    },
    "./canonicalpath": {
      "types": "./dist/canonicalpath/index.d.ts",
      "import": "./dist/canonicalpath/index.js",
      "default": "./dist/canonicalpath/index.js"
    },
    "./canonicalfs": {
      "types": "./dist/canonicalfs/index.d.ts",
      "import": "./dist/canonicalfs/index.js",
      "default": "./dist/canonicalfs/index.js"
    },
    "./unity-gateway": {
      "types": "./dist/unity-gateway/index.d.ts",
      "import": "./dist/unity-gateway/index.js",
      "default": "./dist/unity-gateway/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE.md", "LICENSE.ru.md", "NOTICE.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "package:smoke": "node test/package-smoke.mjs",
    "prepack": "node ../../scripts/sync-npm-package-notices.mjs copy",
    "postpack": "node ../../scripts/sync-npm-package-notices.mjs clean",
    "pack:dry-run": "npm pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "tsc --noEmit"
  }
}
