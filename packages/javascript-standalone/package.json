{
  "name": "@romanilyin/canonicalpath-standalone",
  "version": "2026.5.18-2",
  "description": "Browser-safe standalone CanonicalPath lexical identity helpers.",
  "license": "LicenseRef-Stinger-Royalty-Free-EULA-1.0",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romanilyin/canonicalpath.git",
    "directory": "packages/javascript-standalone"
  },
  "homepage": "https://github.com/romanilyin/canonicalpath#readme",
  "bugs": {
    "url": "https://github.com/romanilyin/canonicalpath/issues"
  },
  "keywords": ["canonicalpath", "path", "browser", "lexical", "path-identity"],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/canonicalpath.js",
  "types": "./dist/canonicalpath.d.ts",
  "exports": {
    ".": {
      "types": "./dist/canonicalpath.d.ts",
      "import": "./dist/canonicalpath.js",
      "default": "./dist/canonicalpath.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE.md", "LICENSE.ru.md", "NOTICE.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:smoke": "node test/build-smoke.mjs",
    "prepack": "node ../../scripts/sync-npm-package-notices.mjs copy",
    "postpack": "node ../../scripts/sync-npm-package-notices.mjs clean",
    "pack:dry-run": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "alloc": "vitest run test/allocation.test.ts",
    "lint": "tsc --noEmit"
  }
}
