{
  "version": 1,
  "scopes": {
    "unity_asset": {
      "allowedRoots": ["Assets", "Packages"],
      "allowedOperations": ["validate", "read", "write", "import", "refresh"],
      "relativeInputFormat": "project-relative path beginning with exact Assets or Packages component",
      "maxPathLength": 4096,
      "maxComponentLength": 255,
      "separatorPolicy": "forward-slash-only",
      "symlinkReparsePolicy": "lexical only; CanonicalFS/Go daemon or Unity bridge must reject filesystem escape",
      "caseSensitivityExpectation": "exact ordinal scope components; host filesystem may differ",
      "unicodeNormalizationPolicy": "preserve input; no normalization",
      "absoluteInputAllowed": false,
      "llmToolArgsAllowed": true,
      "persistedRefsAllowed": true,
      "auditRefsAllowed": true,
      "artifactRefsAllowed": true
    },
    "knowledge": {
      "allowedRoots": ["Assets/UnityMcpKnowledge"],
      "allowedOperations": ["read", "write", "list"],
      "relativeInputFormat": "scope-relative path below Assets/UnityMcpKnowledge",
      "maxPathLength": 2048,
      "maxComponentLength": 255,
      "separatorPolicy": "forward-slash-only",
      "symlinkReparsePolicy": "lexical only; CanonicalFS/Go daemon or Unity bridge must reject filesystem escape",
      "caseSensitivityExpectation": "exact ordinal",
      "unicodeNormalizationPolicy": "preserve input; no normalization",
      "absoluteInputAllowed": false,
      "llmToolArgsAllowed": true,
      "persistedRefsAllowed": true,
      "auditRefsAllowed": true,
      "artifactRefsAllowed": false
    },
    "package_manifest": {
      "allowedRoots": ["Packages/manifest.json", "Packages/packages-lock.json"],
      "allowedOperations": ["read", "write"],
      "relativeInputFormat": "exact project-relative package manifest path",
      "maxPathLength": 128,
      "maxComponentLength": 64,
      "separatorPolicy": "forward-slash-only",
      "symlinkReparsePolicy": "lexical only; CanonicalFS/Go daemon or Unity bridge must reject filesystem escape",
      "caseSensitivityExpectation": "exact ordinal",
      "unicodeNormalizationPolicy": "preserve input; no normalization",
      "absoluteInputAllowed": false,
      "llmToolArgsAllowed": true,
      "persistedRefsAllowed": true,
      "auditRefsAllowed": true,
      "artifactRefsAllowed": true
    },
    "artifact": {
      "allowedRoots": ["Library/SGGUnityMcp/job-artifacts", "Library/SGGUnityMcp/screenshots"],
      "allowedOperations": ["read", "write", "list"],
      "relativeInputFormat": "scope-relative path beginning with exact job-artifacts or screenshots component",
      "maxPathLength": 2048,
      "maxComponentLength": 255,
      "separatorPolicy": "forward-slash-only",
      "symlinkReparsePolicy": "lexical only; CanonicalFS/Go daemon or Unity bridge must reject filesystem escape",
      "caseSensitivityExpectation": "exact ordinal",
      "unicodeNormalizationPolicy": "preserve input; no normalization",
      "absoluteInputAllowed": false,
      "llmToolArgsAllowed": true,
      "persistedRefsAllowed": true,
      "auditRefsAllowed": true,
      "artifactRefsAllowed": true
    },
    "gateway_cache": {
      "allowedRoots": ["platform-local-cache"],
      "allowedOperations": ["read", "write", "delete", "generated-key"],
      "relativeInputFormat": "scope-relative generated cache key under index, never a host path",
      "maxPathLength": 1024,
      "maxComponentLength": 255,
      "separatorPolicy": "forward-slash-only",
      "symlinkReparsePolicy": "lexical only; CanonicalFS/Go daemon must reject cache escape",
      "caseSensitivityExpectation": "exact ordinal",
      "unicodeNormalizationPolicy": "preserve input; no normalization",
      "absoluteInputAllowed": false,
      "llmToolArgsAllowed": false,
      "persistedRefsAllowed": true,
      "auditRefsAllowed": true,
      "artifactRefsAllowed": false
    },
    "temp_session": {
      "allowedRoots": ["Temp/SGGUnityMcp"],
      "allowedOperations": ["read", "write", "delete"],
      "relativeInputFormat": "scope-relative path below Temp/SGGUnityMcp beginning with an exact session component",
      "maxPathLength": 1024,
      "maxComponentLength": 255,
      "separatorPolicy": "forward-slash-only",
      "symlinkReparsePolicy": "lexical only; CanonicalFS/Go daemon or Unity bridge must reject filesystem escape",
      "caseSensitivityExpectation": "exact ordinal",
      "unicodeNormalizationPolicy": "preserve input; no normalization",
      "absoluteInputAllowed": false,
      "llmToolArgsAllowed": true,
      "persistedRefsAllowed": false,
      "auditRefsAllowed": true,
      "artifactRefsAllowed": false
    }
  },
  "cases": [
    { "id": "unity-asset-allow-assets", "scope": "unity_asset", "operation": "read", "raw": "Assets/Scripts/App.cs", "expectedProjectRelative": "Assets/Scripts/App.cs" },
    { "id": "unity-asset-allow-packages", "scope": "unity_asset", "operation": "read", "raw": "Packages/com.example/package.json", "expectedProjectRelative": "Packages/com.example/package.json" },
    { "id": "unity-asset-reject-project-settings", "scope": "unity_asset", "operation": "read", "raw": "ProjectSettings/TagManager.asset", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "unity-asset-reject-assets-sibling", "scope": "unity_asset", "operation": "read", "raw": "AssetsEvil/Scripts/App.cs", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "unity-asset-reject-ads", "scope": "unity_asset", "operation": "read", "raw": "Assets/Scripts/App.cs:Zone.Identifier", "error": "ERR_INVALID_PATH" },
    { "id": "unity-asset-reject-trailing-dot", "scope": "unity_asset", "operation": "read", "raw": "Assets/Scripts/App./Main.cs", "error": "ERR_INVALID_PATH" },
    { "id": "unity-asset-reject-trailing-space", "scope": "unity_asset", "operation": "read", "raw": "Assets/Scripts/App /Main.cs", "error": "ERR_INVALID_PATH" },
    { "id": "knowledge-allow-agent-instructions", "scope": "knowledge", "operation": "read", "raw": "agent-instructions.md", "expectedProjectRelative": "Assets/UnityMcpKnowledge/agent-instructions.md" },
    { "id": "knowledge-reject-traversal", "scope": "knowledge", "operation": "read", "raw": "../UnityMcpKnowledge/agent-instructions.md", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "knowledge-reject-sibling", "scope": "knowledge", "operation": "read", "raw": "Assets/UnityMcpKnowledgeEvil/agent-instructions.md", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "knowledge-reject-project-root-misuse", "scope": "knowledge", "operation": "read", "raw": "Assets/UnityMcpKnowledge/agent-instructions.md", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "artifact-allow-job-summary", "scope": "artifact", "operation": "write", "raw": "job-artifacts/run-1/summary.json", "expectedProjectRelative": "Library/SGGUnityMcp/job-artifacts/run-1/summary.json" },
    { "id": "artifact-allow-screenshot", "scope": "artifact", "operation": "write", "raw": "screenshots/request-1.png", "expectedProjectRelative": "Library/SGGUnityMcp/screenshots/request-1.png" },
    { "id": "artifact-reject-traversal-assets", "scope": "artifact", "operation": "write", "raw": "job-artifacts/run-1/../../Assets/App.cs", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "artifact-reject-traversal-project-settings", "scope": "artifact", "operation": "write", "raw": "screenshots/../../ProjectSettings/TagManager.asset", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "artifact-reject-prefix-sibling", "scope": "artifact", "operation": "write", "raw": "job-artifacts-evil/run-1/summary.json", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "artifact-reject-raw-library-sibling", "scope": "artifact", "operation": "write", "raw": "Library/SGGUnityMcpEvil/job-artifacts/run-1/summary.json", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "artifact-reject-raw-library-traversal", "scope": "artifact", "operation": "write", "raw": "Library/SGGUnityMcp/../../Assets/App.cs", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "package-manifest-allow-manifest", "scope": "package_manifest", "operation": "read", "raw": "Packages/manifest.json", "expectedProjectRelative": "Packages/manifest.json" },
    { "id": "package-manifest-allow-lock", "scope": "package_manifest", "operation": "read", "raw": "Packages/packages-lock.json", "expectedProjectRelative": "Packages/packages-lock.json" },
    { "id": "package-manifest-reject-package-json", "scope": "package_manifest", "operation": "read", "raw": "Packages/com.foo/package.json", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "package-manifest-reject-extra-path", "scope": "package_manifest", "operation": "read", "raw": "Packages/manifest.json/evil", "error": "ERR_INVALID_PATH" },
    { "id": "common-reject-empty", "scope": "unity_asset", "operation": "read", "raw": "", "error": "ERR_EMPTY_PATH" },
    { "id": "common-reject-absolute-posix", "scope": "unity_asset", "operation": "read", "raw": "/repo/Game/Assets/App.cs", "error": "ERR_ABSOLUTE_PATH" },
    { "id": "common-reject-drive-absolute", "scope": "unity_asset", "operation": "read", "raw": "C:/Game/Assets/App.cs", "error": "ERR_ABSOLUTE_PATH" },
    { "id": "common-reject-extended-drive", "scope": "unity_asset", "operation": "read", "raw": "\\\\?\\C:\\Game\\Assets\\App.cs", "error": "ERR_ABSOLUTE_PATH" },
    { "id": "common-reject-extended-unc", "scope": "unity_asset", "operation": "read", "raw": "\\\\?\\UNC\\server\\share\\Assets\\App.cs", "error": "ERR_ABSOLUTE_PATH" },
    { "id": "common-reject-drive-relative", "scope": "unity_asset", "operation": "read", "raw": "C:Assets/App.cs", "error": "ERR_DRIVE_RELATIVE_PATH" },
    { "id": "common-reject-unc", "scope": "unity_asset", "operation": "read", "raw": "\\\\server\\share\\Assets\\App.cs", "error": "ERR_ABSOLUTE_PATH" },
    { "id": "common-reject-nul", "scope": "unity_asset", "operation": "read", "raw": "Assets/Bad\u0000Name.cs", "error": "ERR_NUL_BYTE" },
    { "id": "common-reject-encoded-slash", "scope": "unity_asset", "operation": "read", "raw": "Assets%2fScripts/App.cs", "error": "ERR_ENCODED_SEPARATOR" },
    { "id": "common-reject-encoded-backslash", "scope": "unity_asset", "operation": "read", "raw": "Assets%5cScripts/App.cs", "error": "ERR_ENCODED_SEPARATOR" },
    { "id": "common-reject-double-encoded-slash", "scope": "unity_asset", "operation": "read", "raw": "Assets%252fScripts/App.cs", "error": "ERR_ENCODED_SEPARATOR" },
    { "id": "common-reject-double-encoded-backslash", "scope": "unity_asset", "operation": "read", "raw": "Assets%255cScripts/App.cs", "error": "ERR_ENCODED_SEPARATOR" },
    { "id": "common-reject-file-uri", "scope": "unity_asset", "operation": "read", "raw": "file:///repo/Game/Assets/App.cs", "error": "ERR_UNSUPPORTED_URI_SCHEME" },
    { "id": "gateway-cache-allow-generated-key", "scope": "gateway_cache", "operation": "generated-key", "raw": "index/sha256-abcd1234/result.json", "expectedCacheRelative": "index/sha256-abcd1234/result.json" },
    { "id": "gateway-cache-reject-absolute-raw", "scope": "gateway_cache", "operation": "write", "raw": "/tmp/unity-mcp-cache/result.json", "error": "ERR_ABSOLUTE_PATH" },
    { "id": "gateway-cache-reject-traversal", "scope": "gateway_cache", "operation": "write", "raw": "index/sha256-abcd1234/../../result.json", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "gateway-cache-reject-non-index-prefix", "scope": "gateway_cache", "operation": "write", "raw": "indexes/sha256-abcd1234/result.json", "error": "ERR_OUTSIDE_ROOT" },
    { "id": "temp-session-allow-safe", "scope": "temp_session", "operation": "write", "raw": "session-1/request.json", "expectedProjectRelative": "Temp/SGGUnityMcp/session-1/request.json" },
    { "id": "temp-session-reject-traversal", "scope": "temp_session", "operation": "write", "raw": "session-1/../../ProjectSettings/TagManager.asset", "error": "ERR_OUTSIDE_ROOT" }
  ]
}
