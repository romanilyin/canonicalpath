{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canonicalpath.dev/spec/language-targets.schema.json",
  "title": "CanonicalPath Language Targets",
  "type": "object",
  "required": ["version", "targets"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/target" }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "required": ["id", "language", "status", "surfaces", "securityBoundary", "allocationChecks"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "language": { "type": "string", "minLength": 1 },
        "status": { "enum": ["supported", "planned", "blocked"] },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["canonicalpath", "canonicalfs", "daemon", "http-client", "rpc-client", "unity-managed", "unity-burst"]
          },
          "uniqueItems": true
        },
        "securityBoundary": { "type": "string", "minLength": 1 },
        "unityVersion": { "type": "string", "minLength": 1 },
        "burst": { "type": "boolean" },
        "notes": { "type": "string" },
        "allocationChecks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/allocationCheck" }
        }
      }
    },
    "allocationCheck": {
      "type": "object",
      "required": ["id", "status", "command", "metric"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "status": { "enum": ["active", "planned", "blocked"] },
        "command": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    }
  }
}
